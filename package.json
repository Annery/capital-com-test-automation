{
  "name": "capital-com-test-automation",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "auth": "node -e \"require('fs').rmSync('.auth',{recursive:true,force:true})\" && playwright test --project=setup --headed",
    "secret:auth": "powershell -NoProfile -Command \"[Convert]::ToBase64String([IO.File]::ReadAllBytes('.auth/authorized.json')) | Set-Clipboard\"",
    "secret:unauth": "powershell -NoProfile -Command \"[Convert]::ToBase64String([IO.File]::ReadAllBytes('.auth/unauthorized.json')) | Set-Clipboard\"",
    "check": "tsc --noEmit && eslint . && playwright test --list",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "allure-playwright": "^3.10.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-playwright": "^2.10.4",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  }
}
